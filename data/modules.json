    {"id": "s20", "s": "ps", "w": 2, "t": "Uniform distribution (discrete)", "f": "p(x)=\\dfrac1n,\\ E[X]=\\dfrac{n+1}{2}"},
    {"id": "s21", "s": "ps", "w": 2, "t": "Bernoulli distribution", "f": "P(X{=}1)=p,\\ E[X]=p,\\ Var(X)=p(1-p)"},
    {"id": "s22", "s": "ps", "w": 2, "t": "Binomial distribution", "f": "P(X{=}k)=\\binom{n}{k}p^k(1-p)^{n-k},\\ E[X]=np"},
    {"id": "s23", "s": "ps", "w": 2, "t": "Continuous random variables & probability distribution function", "f": "P(a\\le X\\le b)=\\int_a^b f(x)\\,dx,\\ \\int f(x)\\,dx=1"},
