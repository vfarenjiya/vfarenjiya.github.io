    {"id": "s0", "s": "ps", "w": 1, "t": "Counting: permutations and combinations", "f": "nPr = \\dfrac{n!}{(n-r)!},\\quad nCr = \\dfrac{n!}{r!(n-r)!}"},
    {"id": "s1", "s": "ps", "w": 1, "t": "Probability axioms", "f": "P(\\Omega)=1,\\ P(A)\\ge 0,\\ P\\left(\\bigcup_i A_i\\right)=\\sum_i P(A_i)"},
    {"id": "s2", "s": "ps", "w": 1, "t": "Sample space", "f": "P(A)=\\dfrac{n(A)}{n(\\Omega)}"},
    {"id": "s3", "s": "ps", "w": 1, "t": "Events", "f": "P(A^c) = 1-P(A)"},
    {"id": "s4", "s": "ps", "w": 1, "t": "Independent events", "f": "P(A\\cap B) = P(A)\\,P(B)"},
    {"id": "s5", "s": "ps", "w": 1, "t": "Mutually exclusive events", "f": "P(A\\cap B)=0 \\Rightarrow P(A\\cup B)=P(A)+P(B)"},
    {"id": "s6", "s": "ps", "w": 1, "t": "Marginal probability", "f": "P(A) = \\sum_j P(A \\cap B_j)"},
    {"id": "s7", "s": "ps", "w": 1, "t": "Conditional probability", "f": "P(A|B) = \\dfrac{P(A\\cap B)}{P(B)}"},
    {"id": "s8", "s": "ps", "w": 1, "t": "Joint probability", "f": "P(A\\cap B) = P(A|B)P(B) = P(B|A)P(A)"},
    {"id": "s9", "s": "ps", "w": 1, "t": "Bayes' theorem", "f": "P(A_i|B) = \\dfrac{P(B|A_i)P(A_i)}{\\sum_j P(B|A_j)P(A_j)}"},
    {"id": "s10", "s": "ps", "w": 1, "t": "Conditional expectation", "f": "E[X|Y{=}y] = \\sum_x x\\,P(X{=}x|Y{=}y)"},
    {"id": "s11", "s": "ps", "w": 1, "t": "Conditional variance", "f": "Var(X) = E[Var(X|Y)] + Var(E[X|Y])"},
    {"id": "s12", "s": "ps", "w": 1, "t": "Mean", "f": "E[X] = \\sum_x x\\,p(x)\\quad \\text{or}\\quad \\int x f(x)\\,dx"},
    {"id": "s13", "s": "ps", "w": 2, "t": "Median", "f": "\\text{value } m:\\ P(X\\le m)\\ge \\tfrac12,\\ P(X\\ge m)\\ge \\tfrac12"},
